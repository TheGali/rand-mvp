run = "python -m uvicorn app:app --host 0.0.0.0 --port 8080"
entrypoint = "app.py"
modules = ["python-3.11:v18-20230807-322e88b"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["python", "-m", "uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8080"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80

[env]
PYTHONUNBUFFERED = "1"
